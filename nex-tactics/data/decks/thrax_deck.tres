[gd_resource type="Resource" script_class="DeckData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/data/deck_data.gd" id="1_deck_data"]

[resource]
script = ExtResource("1_deck_data")
id = "thrax"
display_name = "Deck do Rei Thrax"
description = "Deck focado em pressao fisica e escalada economica. Quanto mais ouro guardado, mais perigoso fica o exercito."
