card_pool_paths = PackedStringArray("res://data/cards/thrax/toque_de_midas.tres", "res://data/cards/thrax/saque_de_tributo.tres", "res://data/cards/thrax/armadura_de_guerra.tres", "res://data/cards/thrax/lanca_de_leonidas.tres", "res://data/cards/thrax/tornado.tres")
