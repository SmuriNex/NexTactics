card_pool_paths = PackedStringArray("res://data/cards/necromancer/book_of_chaos.tres", "res://data/cards/necromancer/cloak_of_darkness.tres", "res://data/cards/necromancer/blinding_mist.tres", "res://data/cards/necromancer/blood_pact.tres", "res://data/cards/necromancer/bone_prison.tres")
