[ext_resource type="Script" path="res://scripts/data/deck_data.gd" id="1_deck_data"]

[resource]
script = ExtResource("1_deck_data")
id = "mordos"
display_name = "Deck de Mordos, o Necromante"
description = "Deck kamikaze de mortos-vivos e ogros corrompidos liderado por um humano. Vence por sacrificio, mortes em cadeia e snowball agressivo."
